# =========================
# 🐍 PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribución / empaquetado
build/
dist/
*.egg-info/
.eggs/

# =========================
# 🧪 ENTORNOS VIRTUALES
# =========================
venv/
env/
ENV/
venv-cmvida/
# Cubre otros nombres comunes de entornos
.venv/
.env/

# =========================
# 🌐 DJANGO
# =========================
db.sqlite3
db.sqlite3-journal

# Archivos generados
media/
staticfiles/

# Configuración local
local_settings.py

# =========================
# 🔐 VARIABLES DE ENTORNO
# =========================
.env
.env.*
!.env.example
*.env

# =========================
# 📊 ARCHIVOS DEL PROYECTO
# =========================
# Archivos subidos por usuarios
uploads/

# Excel / PDF (datos reales/sensibles)
*.xlsx
*.xls
*.pdf
*.csv

# =========================
# 🌐 NODE / FRONTEND
# =========================
node_modules/
**/node_modules/

.next/
out/
# dist/ y build/ ya están arriba en Python, pero se mantienen por claridad
coverage/

# Cache frontend
.cache/
.temp/
.tmp/
**/.cache/
**/.temp/
**/.tmp/

# =========================
# 🧾 LOGS
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 🧪 TEST / COVERAGE
# =========================
.coverage
htmlcov/
.tox/
.pytest_cache/
*.lcov

# =========================
